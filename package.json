{
  "name": "templecv",
  "version": "0.1.0",
  "description": "Local-first desktop TempleCV with structured resume packages and deterministic exports.",
  "main": ".vite/build/main.js",
  "private": true,
  "author": "Tony",
  "type": "module",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "tsc --noEmit && vite build --config vite.renderer.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@vitejs/plugin-react": "^5.1.2",
    "docx": "^9.5.1",
    "jszip": "^3.10.1",
    "qrcode-svg": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.3",
    "@electron-forge/maker-dmg": "^7.8.3",
    "@electron-forge/maker-squirrel": "^7.8.3",
    "@electron-forge/maker-zip": "^7.8.3",
    "@electron-forge/plugin-fuses": "^7.8.3",
    "@electron-forge/plugin-vite": "^7.8.3",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^24.12.2",
    "@types/qrcode-svg": "^1.1.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^38.1.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
